# Backend — copier en .env et remplir. Ne JAMAIS committer le .env réel.

# --- MongoDB ---
MONGO_URI=
DB_NAME=chezmamie

# --- JWT ---
# OBLIGATOIRE : le serveur refuse de démarrer sans.
# Générer : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_ADMIN_SECRET=

# --- Superadmin initial (créé au 1er démarrage si la base n'a aucun admin) ---
SUPERADMIN_NAME=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# --- CORS / Frontend ---
FRONT_ORIGIN=

# --- Serveur ---
PORT=5000
