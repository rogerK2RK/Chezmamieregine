# Variables d'environnement du backend — copier en .env et remplir les valeurs.
# Ne jamais committer le .env réel.

# --- Base de données MongoDB ---
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=chezmamie

# --- Secrets JWT (OBLIGATOIRES) ---
# JWT_SECRET est requis : le serveur refuse de démarrer s'il est absent.
# Générer une valeur aléatoire forte, ex. : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Optionnel : secret dédié aux tokens admin. Si vide, JWT_SECRET est utilisé.
JWT_ADMIN_SECRET=

# --- Superadmin initial (créé au démarrage si absent) ---
SUPERADMIN_NAME=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# --- CORS / Frontend ---
# Origine supplémentaire autorisée (en plus de localhost et du domaine Vercel).
FRONT_ORIGIN=

# --- Serveur (local uniquement) ---
PORT=5000
